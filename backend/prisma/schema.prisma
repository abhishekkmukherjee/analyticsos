// Prisma schema — AnalyticsOS
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

/// A customer organization. The root of tenant isolation — every row that
/// belongs to a customer carries a `tenantId` foreign key back to here.
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      String   @default("starter")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  connections Connection[]
}

/// A person inside a tenant. `authId` is the external identity-provider id
/// (Clerk user id later; today it's whatever the stub auth guard hands us).
model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  email     String
  name      String?
  role      String   @default("member")
  authId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

/// A configured data-source connection for a tenant (e.g. a GA4 property).
/// Credentials live in `config` (encrypted at rest later); status tracks sync.
model Connection {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  source      String // 'ga4', 'meta_ads', 'nginx_logs', ...
  displayName String
  status      String    @default("pending") // pending | active | error
  config      Json      @default("{}")
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, source])
}

/// Time-series metric point. This is the Postgres implementation of the guide's
/// ClickHouse `metrics` table — the MetricsStore interface lets a ClickHouse
/// backend replace it later without touching connectors or the query API.
/// No FK to Tenant on purpose: mirrors the columnar design and keeps writes cheap.
model Metric {
  id         Int      @id @default(autoincrement())
  tenantId   String   @db.Uuid
  source     String // 'ga4', 'stripe', 'meta_ads', ...
  metricName String // 'sessions', 'revenue', 'error_5xx', ...
  dimensions Json     @default("{}")
  value      Float
  recordedAt DateTime
  ingestedAt DateTime @default(now())

  @@index([tenantId, source, metricName, recordedAt])
}

/// A single log line/event from an infra source (nginx, docker, aws, ...).
/// Rows arrive two ways: a log connector's sync (mock or provider API pull)
/// and the Vector.dev push endpoint (POST /logs/ingest). Like Metric, no FK
/// to Tenant — this table is high-volume and ClickHouse-bound later.
model LogEvent {
  id         Int      @id @default(autoincrement())
  tenantId   String   @db.Uuid
  source     String // 'nginx_logs', 'docker_logs', 'aws_logs', ...
  level      String // 'debug' | 'info' | 'warn' | 'error'
  message    String
  host       String?
  service    String?
  metadata   Json     @default("{}")
  timestamp  DateTime
  ingestedAt DateTime @default(now())

  @@index([tenantId, source, timestamp])
  @@index([tenantId, level, timestamp])
}

/// A detected metric anomaly (Phase 3: log error spikes; Phase 4 widens this
/// to every metric). One row per (source, metric, window) finding — detection
/// re-runs replace the window's open rows so re-detection never duplicates.
model Anomaly {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  source      String
  metricName  String
  severity    String // 'warning' | 'critical'
  zscore      Float
  observed    Float
  expected    Float
  windowStart DateTime
  windowEnd   DateTime
  status      String   @default("open") // open | acknowledged | resolved
  context     Json     @default("{}")
  detectedAt  DateTime @default(now())

  @@index([tenantId, detectedAt])
  @@index([tenantId, status])
}
