# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored (never committed); this template is safe to commit.

# App identity
APP_NAME=AnalyticsOS API
APP_VERSION=0.1.0

# Port the API server listens on
PORT=3000

# development | production. In development the auth guard auto-provisions a
# demo tenant/user when no auth headers are present.
NODE_ENV=development

# PostgreSQL connection string (Neon, Supabase, local, ...).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Optional: features run in mock mode until these are set ---

# Claude chat. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# GA4 connector live mode (both required to leave mock mode)
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=
